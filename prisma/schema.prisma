// This is your Prisma schema file for AYAM GEPREK SAMBAL IJO Restaurant System
// Digital Restaurant + POS System with Complete Features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User & Role Management
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STAFF)
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cashierShifts  CashierShift[]
  voidLogs       VoidLog[]
  transactions   Transaction[]
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  STAFF
  USER
}

// Category Management
model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]
}

// Product Management
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  barcode     String?  @unique
  sku         String?  @unique
  categoryId  String
  image       String?
  stock       Int      @default(0)
  minStock    Int      @default(5)
  cost        Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category        Category             @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  transactionItems TransactionItem[]
  stockLogs       StockLog[]
  promos          ProductPromo[]

  @@index([categoryId])
  @@index([barcode])
  @@index([sku])
}

// Customer/Member Management
model Member {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String
  email     String?
  address   String?
  points    Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  pointHistory  PointHistory[]
  transactions  Transaction[]
}

// Online Orders
model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  memberId        String?
  customerName    String
  customerPhone   String
  customerAddress String
  status          OrderStatus   @default(PENDING)
  totalAmount     Float
  discountAmount  Float         @default(0)
  pointsUsed      Int           @default(0)
  pointsEarned    Int           @default(0)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  paymentUrl      String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  member      Member?      @relation(fields: [memberId], references: [id])
  items       OrderItem[]
  transaction Transaction?

  @@index([orderNumber])
  @@index([memberId])
  @@index([status])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
  DELIVERED
}

enum PaymentMethod {
  CASH
  QRIS_CPM
  DEBIT
  CREDIT
  TRANSFER
  E_WALLET
  SPLIT
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  discount  Float    @default(0)
  subtotal  Float
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// POS Transactions
model Transaction {
  id              String          @id @default(cuid())
  transactionNo   String          @unique
  orderId         String?         @unique
  cashierId       String
  memberId        String?
  shiftId         String
  totalAmount     Float
  discountAmount  Float           @default(0)
  taxAmount       Float           @default(0)
  finalAmount     Float
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus   @default(PAID)
  cashReceived    Float?
  changeAmount    Float?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  cashier   User              @relation(fields: [cashierId], references: [id])
  member    Member?           @relation(fields: [memberId], references: [id])
  shift     CashierShift      @relation(fields: [shiftId], references: [id])
  order     Order?            @relation(fields: [orderId], references: [id])
  items     TransactionItem[]
  payments  Payment[]

  @@index([transactionNo])
  @@index([cashierId])
  @@index([shiftId])
  @@index([memberId])
}

model TransactionItem {
  id             String   @id @default(cuid())
  transactionId  String
  productId      String
  quantity       Int
  price          Float
  discount       Float    @default(0)
  subtotal       Float
  cost           Float?
  createdAt      DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

model Payment {
  id             String          @id @default(cuid())
  transactionId  String
  paymentMethod  PaymentMethod
  amount         Float
  reference      String?
  status         PaymentStatus   @default(PAID)
  createdAt      DateTime        @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
}

// Cashier Shift Management
model CashierShift {
  id            String    @id @default(cuid())
  cashierId     String
  cashierName   String
  openingBalance Float
  closingBalance Float?
  totalSales    Float     @default(0)
  cashSales     Float     @default(0)
  nonCashSales  Float     @default(0)
  systemBalance Float     @default(0)
  physicalBalance Float?
  difference    Float?
  status        ShiftStatus @default(OPEN)
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cashier      User          @relation(fields: [cashierId], references: [id])
  transactions Transaction[]

  @@index([cashierId])
  @@index([status])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// Stock Management
model StockLog {
  id        String       @id @default(cuid())
  productId String
  quantity  Int
  type      StockType
  reason    String?
  reference String?
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

enum StockType {
  IN
  OUT
  ADJUSTMENT
  INITIAL
}

// Member Points System
model PointHistory {
  id        String      @id @default(cuid())
  memberId  String
  points    Int
  type      PointType
  reference String?
  notes     String?
  createdAt DateTime    @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
}

enum PointType {
  EARNED
  REDEEMED
  ADJUSTMENT
}

// Promotion System
model Promo {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        PromoType
  value       Float
  startDate   DateTime
  endDate     DateTime?
  minPurchase Float?
  maxDiscount Float?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products ProductPromo[]

  @@index([type])
  @@index([isActive])
}

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_1_GET_1
  BUNDLE
}

model ProductPromo {
  promoId   String
  productId String
  createdAt DateTime @default(now())

  promo   Promo   @relation(fields: [promoId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promoId, productId])
  @@index([promoId])
  @@index([productId])
}

// Void Transaction System
model VoidLog {
  id             String   @id @default(cuid())
  transactionId  String?
  itemId         String?
  type           VoidType
  reason         String
  amount         Float
  supervisorPin  String
  cashierId      String
  cashierName    String
  createdAt      DateTime @default(now())

  cashier User @relation(fields: [cashierId], references: [id])

  @@index([cashierId])
  @@index([transactionId])
}

enum VoidType {
  ITEM
  TRANSACTION
}

// System Settings
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([category])
}

// Notification Queue (for WhatsApp)
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  recipient String
  message   String
  status    NotificationStatus @default(PENDING)
  attempts  Int              @default(0)
  sentAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
  @@index([type])
}

enum NotificationType {
  ORDER_NEW
  ORDER_CONFIRMED
  ORDER_COMPLETED
  PAYMENT_RECEIVED
  STOCK_LOW
  STOCK_EMPTY
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// QRIS Payment Management
model QRISPayment {
  id              String              @id @default(cuid())
  orderId         String              @unique
  paymentId       String              @unique
  gateway         QRISPaymentGateway
  amount          Float
  customerName    String
  customerEmail   String?
  customerPhone   String?
  status          PaymentStatus       @default(PENDING)
  transactionId   String?
  paidAmount      Float?
  paymentMethod   String?
  qrCode          String
  qrString        String
  paymentUrl      String?
  expiryTime      DateTime
  paidAt          DateTime?
  metadata        String?             // JSON string
  callbackReceived Boolean           @default(false)
  callbackAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([orderId])
  @@index([paymentId])
  @@index([status])
  @@index([gateway])
}

enum QRISPaymentGateway {
  MIDTRANS
  XENDIT
  TRIPAY
}

// Dynamic Development System
// Dynamic Tabs - Custom tabs for admin panel
model DynamicTab {
  id        String   @id @default(cuid())
  name      String
  label     String
  icon      String?  // Icon name from lucide-react
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pages     DynamicPage[]

  @@index([isActive])
  @@index([order])
}

// Dynamic Pages - Pages within tabs
model DynamicPage {
  id        String   @id @default(cuid())
  tabId     String
  name      String
  title     String
  description String?
  order     Int      @default(0)
  layout    String   @default("grid") // grid, list, card, table
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tab       DynamicTab @relation(fields: [tabId], references: [id], onDelete: Cascade)
  features  DynamicFeature[]

  @@index([tabId])
  @@index([isActive])
  @@index([order])
}

// Dynamic Features - Components/widgets within pages
model DynamicFeature {
  id          String   @id @default(cuid())
  pageId      String
  name        String
  title       String
  type        FeatureType @default(CARD)
  content     String   // JSON string for feature configuration
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page        DynamicPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([type])
  @@index([isVisible])
  @@index([order])
}

enum FeatureType {
  CARD
  CHART
  TABLE
  LIST
  STAT
  FORM
  BUTTON
  TEXT
  IMAGE
  DIVIDER
}
